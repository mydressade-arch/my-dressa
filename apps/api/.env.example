# =============================================
# My Dressa — API Environment Variables
# Kopiere diese Datei zu .env und fülle aus!
# =============================================

# PostgreSQL — mit pgAdmin lokal
# Format: postgresql://USER:PASSWORT@HOST:PORT/DATENBANKNAME
DATABASE_URL=postgresql://postgres:DEIN_PASSWORT@localhost:5432/dressa_db

# Redis — falls lokal installiert, sonst weglassen fürs erste
# REDIS_URL=redis://localhost:6379

# JWT — beliebige lange zufällige Strings
JWT_SECRET=my_dressa_super_secret_jwt_key_change_in_production_2024
JWT_REFRESH_SECRET=my_dressa_refresh_secret_also_change_in_production_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Node Environment
NODE_ENV=development

# Stripe — Testkeys von dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_DEIN_STRIPE_TEST_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_DEIN_STRIPE_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_DEIN_WEBHOOK_SECRET

# Frontend URL
FRONTEND_URL=http://localhost:3000

# AWS S3 — kann erstmal leer bleiben, Bilder werden dann nicht hochgeladen
# AWS_S3_BUCKET=my-dressa-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# ─── Resend E-Mail Service ─────────────────────────────────────────────────
# Account erstellen auf resend.com → API Keys → Key kopieren
RESEND_API_KEY=re_DEIN_RESEND_API_KEY
EMAIL_FROM=My Dressa <noreply@mydressa.de>

# Zum Testen: alle E-Mails an diese Adresse umleiten (Resend Free Plan)
# Entfernen wenn Domain verifiziert ist
EMAIL_TEST_OVERRIDE=mahmoodads12@gmail.com

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# dashboard.cloudflare.com → R2 → Bucket erstellen → API Tokens
# Account ID findest du auf der R2 Hauptseite oben rechts
AWS_ACCESS_KEY_ID=dein_r2_access_key_id
AWS_SECRET_ACCESS_KEY=dein_r2_secret_access_key
AWS_S3_BUCKET=my-dressa-images
AWS_REGION=auto
AWS_ENDPOINT=https://DEINE_ACCOUNT_ID.r2.cloudflarestorage.com
# Public Domain: Bucket → Settings → Public Access aktivieren
AWS_ENDPOINT_PUBLIC=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ─── Brevo E-Mail (kostenlos, kein Kreditkarte) ───────────────────────────────
# brevo.com → Settings → SMTP & API → SMTP
BREVO_SMTP_USER=deine@email.de
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxx
EMAIL_FROM=My Dressa <noreply@mydressa.de>
